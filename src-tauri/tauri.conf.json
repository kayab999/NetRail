{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetRail",
  "mainBinaryName": "netrail",
  "version": "1.2.1",
  "identifier": "io.netrail.NetRail",
  "build": {
    "frontendDist": "../netrail/static",
    "devUrl": "http://127.0.0.1:7421",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NetRail",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "url": "http://127.0.0.1:7421"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://127.0.0.1:7421 ws://127.0.0.1:*; frame-ancestors 'none'; base-uri 'self'; form-action 'self'",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/netrail/static/": "../netrail/static/"
        }
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {
          "usr/share/netrail/static/": "../netrail/static/"
        }
      }
    }
  },
  "plugins": {}
}